{
  "manifest_version": 3,
  "name": "AniList Custom Background",
  "version": "1.1",
  "description": "AniList with custom video background + navbar tweaks",
  "permissions": ["storage", "tabs"],
  "action": { "default_popup": "popup.html" },
  "content_scripts": [
    {
      "matches": ["https://anilist.co/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  }
}
